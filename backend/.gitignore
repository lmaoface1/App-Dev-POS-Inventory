cat > backend/.gitignore << 'EOF'
# Dependencies
node_modules/

# Environment variables — NEVER commit real .env
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*

# Build output
dist/
build/

# OS files
.DS_Store
Thumbs.db
EOF

# Environment variables — NEVER commit real .env
.env
.env.local
.env.*.local
